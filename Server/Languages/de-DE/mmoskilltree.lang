# MMOSkillMasteryPack - Quest-Titel + Fließtext, Währungsnamen und sonstiger Anzeigetext.
# Die Schlüssel stehen ohne Präfix; Hytales I18nModule stellt den Dateinamen voran, sodass jeder
# als mmoskilltree.<key> geladen und vom Mod per Konvention aufgelöst wird (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Füge eine <locale>/mmoskilltree.lang mit
# denselben Schlüsseln hinzu, um zu übersetzen; fehlende Schlüssel fallen pro Schlüssel auf Englisch zurück.

# --- Quests (quest.<id>.title / .flavor, per Konvention aufgelöst; folgt dem Kopfgeld-Muster) ---
quest.pack_first_milestone.title = Erster Schritt zur Mastery
quest.pack_first_milestone.flavor = Erreiche Stufe 15 in einer beliebigen Fähigkeit, um deinen ersten Mastery-Punkt zu verdienen. Der Pfad der Mastery beginnt hier.
quest.pack_essence_collector.title = Essenz-Sammler
quest.pack_essence_collector.flavor = Lebensessenz treibt die Mastery an. Bring 100 zum Altar und verdiene dauerhafte Macht.
quest.pack_essence_devotee.title = Essenz-Anhänger
quest.pack_essence_devotee.flavor = Für jene, die ihre Hingabe bereits bewiesen haben: bring 500 Lebensessenz und verdiene einen großen Mastery-Beutel.
quest.pack_path_of_mastery.title = Pfad der Mastery
quest.pack_path_of_mastery.flavor = Wahre Mastery ist breit gefächert. Erreiche Stufe 25 in fünf verschiedenen Fähigkeiten, um deine Bandbreite zu beweisen.
quest.pack_mastery_tithe.title = Mastery-Tribut
quest.pack_mastery_tithe.flavor = Zahle deinen Tribut an den Mastery-Kodex. Erschlage 10 Mobs und schlage 10 Stämme, dann beanspruche einen Mastery-Punkt. Erfordert Gesamtstufe 500 und den Erfolg "Mastery-Hamster". Nach jedem Beanspruchen erst wieder nach 6 Stunden verfügbar.

# --- Token-Shop-Angebote, die dieser Pack ausliefert (explizite titleKey/descriptionKey -> diese Schlüssel) ---
shop.convert_mastery_point.title = Mastery-Infusion (+1 Mastery-Punkt)
shop.convert_mastery_point.desc = Wandle Kopfgeld-Token in einen Mastery-Punkt um.

# --- Währungen (currency.<id>.name, per Konvention aufgelöst; id = Dateiname in Kleinbuchstaben) ---
currency.life_essence.name = Lebensessenz
currency.mastery_point.name = Mastery-Punkt

