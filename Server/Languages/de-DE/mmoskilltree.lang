# --- Erfolge (achievement.<id>.title / .desc, per Konvention aufgelöst) ---
achievement.pack_first_mastery_milestone.title = Lehrling des Pfades
achievement.pack_first_mastery_milestone.desc = Erreiche Stufe 15 in einer beliebigen Fähigkeit - der erste Mastery-Punkt-Meilenstein.
achievement.pack_mastery_milestone_journeyman.title = Geselle des Pfades
achievement.pack_mastery_milestone_journeyman.desc = Erreiche Stufe 60 in einer beliebigen Fähigkeit - vier Mastery-Punkt-Meilensteine verdient.
achievement.pack_mastery_hoarder_300.title = Mastery-Hamster
achievement.pack_mastery_hoarder_300.desc = Verdiene im Laufe deines Lebens 300 Mastery-Punkte.
achievement.pack_mastery_devotee.title = Anhänger der Mastery
achievement.pack_mastery_devotee.desc = Die volle Mastery-Reise: ein Lehrling, ein Geselle und ein Hamster.
achievement.pack_essence_hoarder_100.title = Essenz-Hamster I
achievement.pack_essence_hoarder_100.desc = Sammle 100-mal Lebensessenz auf
achievement.pack_essence_hoarder_10000.title = Essenz-Hamster II
achievement.pack_essence_hoarder_10000.desc = Sammle im Laufe deines Lebens 10.000-mal Lebensessenz auf - ein wahres Gefäß für die Energie der Welt.
