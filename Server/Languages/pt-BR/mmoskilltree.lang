# --- Conquistas (achievement.<id>.title / .desc, resolvidas por convenção) ---
achievement.pack_first_mastery_milestone.title = Aprendiz do Caminho
achievement.pack_first_mastery_milestone.desc = Alcance o nível 15 em qualquer habilidade - o primeiro marco de Ponto de Maestria.
achievement.pack_mastery_milestone_journeyman.title = Oficial do Caminho
achievement.pack_mastery_milestone_journeyman.desc = Alcance o nível 60 em qualquer habilidade - quatro marcos de Ponto de Maestria conquistados.
achievement.pack_mastery_hoarder_300.title = Acumulador de Maestria
achievement.pack_mastery_hoarder_300.desc = Ganhe 300 Pontos de Maestria ao longo da sua vida.
achievement.pack_mastery_devotee.title = Devoto da Maestria
achievement.pack_mastery_devotee.desc = A jornada completa da maestria: um aprendiz, um oficial e um acumulador.
achievement.pack_essence_hoarder_100.title = Acumulador de Essência I
achievement.pack_essence_hoarder_100.desc = Colete Essência de Vida 100 vezes diferentes
achievement.pack_essence_hoarder_10000.title = Acumulador de Essência II
achievement.pack_essence_hoarder_10000.desc = Colete Essência de Vida 10.000 vezes diferentes ao longo da sua vida - um verdadeiro receptáculo da energia do mundo.

