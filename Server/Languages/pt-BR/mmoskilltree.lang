# --- Conquistas (achievement.<id>.title / .desc, resolvidas por convenção) ---
achievement.pack_first_mastery_milestone.title = Aprendiz do Caminho
achievement.pack_first_mastery_milestone.desc = Alcance seu primeiro marco de maestria.
achievement.pack_mastery_milestone_journeyman.title = Oficial do Caminho
achievement.pack_mastery_milestone_journeyman.desc = Suba alto o bastante em qualquer habilidade para acumular vários marcos pelo caminho.
achievement.pack_mastery_hoarder_300.title = Acumulador de Maestria
achievement.pack_mastery_hoarder_300.desc = Acumule um tesouro de maestria ao longo da sua vida.
achievement.pack_mastery_devotee.title = Devoto da Maestria
achievement.pack_mastery_devotee.desc = A jornada completa da maestria: um aprendiz, um oficial e um acumulador.
