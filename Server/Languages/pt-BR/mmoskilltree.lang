# MMOSkillMasteryPack - títulos de missões + ambientação, nomes de moedas e outros textos de exibição.
# As chaves são simples; o I18nModule do Hytale prefixa o nome do arquivo, então cada uma carrega como
# mmoskilltree.<key> e o mod a resolve por convenção (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Adicione um <locale>/mmoskilltree.lang com
# as mesmas chaves para traduzir; chaves ausentes recorrem ao inglês por chave.

# --- Missões (quest.<id>.title / .flavor, resolvidas por convenção; segue o padrão das recompensas) ---
quest.pack_first_milestone.title = Primeiro Passo Rumo à Maestria
quest.pack_first_milestone.flavor = Alcance o nível 15 em qualquer habilidade para ganhar seu primeiro Ponto de Maestria. O caminho da maestria começa aqui.
quest.pack_essence_collector.title = Coletor de Essência
quest.pack_essence_collector.flavor = A Essência de Vida alimenta a maestria. Traga 100 ao altar e ganhe poder duradouro.
quest.pack_essence_devotee.title = Devoto da Essência
quest.pack_essence_devotee.flavor = Para aqueles que já provaram sua dedicação: traga 500 Essências de Vida e ganhe uma grande bolsa de maestria.
quest.pack_path_of_mastery.title = Caminho da Maestria
quest.pack_path_of_mastery.flavor = A verdadeira maestria é ampla. Alcance o nível 25 em cinco habilidades diferentes para provar sua versatilidade.
quest.pack_mastery_tithe.title = Dízimo da Maestria
quest.pack_mastery_tithe.flavor = Pague seu dízimo ao códice da maestria. Abata 10 mobs e corte 10 toras, depois reivindique um Ponto de Maestria. Requer Nível Total 500 e a conquista Acumulador de Maestria. Disponível novamente 6 horas após cada resgate.

# --- Ofertas da Loja de Fichas enviadas por este pack (titleKey/descriptionKey explícitos -> estas chaves) ---
shop.convert_mastery_point.title = Infusão de Maestria (+1 Ponto de Maestria)
shop.convert_mastery_point.desc = Converta Fichas de Recompensa em um Ponto de Maestria.

# --- Moedas (currency.<id>.name, resolvido por convenção; id = nome do arquivo em minúsculas) ---
currency.life_essence.name = Essência de Vida
currency.mastery_point.name = Ponto de Maestria

