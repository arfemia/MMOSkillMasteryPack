# --- Obiettivi (achievement.<id>.title / .desc, risolti per convenzione) ---
achievement.pack_first_mastery_milestone.title = Apprendista del Cammino
achievement.pack_first_mastery_milestone.desc = Raggiungi il livello 15 in una qualsiasi abilita' - il primo traguardo del Punto Maestria.
achievement.pack_mastery_milestone_journeyman.title = Esperto del Cammino
achievement.pack_mastery_milestone_journeyman.desc = Raggiungi il livello 60 in una qualsiasi abilita' - quattro traguardi del Punto Maestria guadagnati.
achievement.pack_mastery_hoarder_300.title = Accumulatore di Maestria
achievement.pack_mastery_hoarder_300.desc = Guadagna 300 Punti Maestria nel corso della tua vita.
achievement.pack_mastery_devotee.title = Devoto della Maestria
achievement.pack_mastery_devotee.desc = L'intero viaggio della maestria: un apprendista, un esperto e un accumulatore.
achievement.pack_essence_hoarder_100.title = Accumulatore d'Essenza I
achievement.pack_essence_hoarder_100.desc = Raccogli Essenza Vitale 100 volte diverse
achievement.pack_essence_hoarder_10000.title = Accumulatore d'Essenza II
achievement.pack_essence_hoarder_10000.desc = Raccogli Essenza Vitale 10.000 volte diverse nel corso della tua vita - un vero vascello per l'energia del mondo.
