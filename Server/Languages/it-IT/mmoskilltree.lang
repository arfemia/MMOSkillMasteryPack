# MMOSkillMasteryPack - titoli delle missioni + testo descrittivo, nomi delle valute e altro testo visualizzato.
# Le chiavi sono nude; l'I18nModule di Hytale antepone il nome del file, quindi ognuna viene caricata
# come mmoskilltree.<key> e il mod la risolve per convenzione (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Aggiungi un <locale>/mmoskilltree.lang con
# le stesse chiavi per tradurre; le chiavi mancanti ricadono sull'inglese per singola chiave.

# --- Missioni (quest.<id>.title / .flavor, risolte per convenzione; segue lo schema delle taglie) ---
quest.pack_first_milestone.title = Primo Passo verso la Maestria
quest.pack_first_milestone.flavor = Mettiti alla prova in una qualsiasi abilita' per raggiungere il tuo primo traguardo di maestria. Il cammino della maestria comincia qui.
quest.pack_essence_collector.title = Collezionista d'Essenza
quest.pack_essence_collector.flavor = L'essenza del mondo alimenta la maestria. Porta un'offerta all'altare e guadagna potere duraturo.
quest.pack_essence_devotee.title = Devoto dell'Essenza
quest.pack_essence_devotee.flavor = Per chi ha gia' provato la propria dedizione: un'offerta piu' grande in cambio di una cospicua borsa di maestria.
quest.pack_path_of_mastery.title = Il Cammino della Maestria
quest.pack_path_of_mastery.flavor = La vera maestria e' ampia. Sali in alto in diverse abilita' per dimostrare la tua versatilita'.
quest.pack_mastery_tithe.title = Decima della Maestria
quest.pack_mastery_tithe.flavor = Versa la tua decima al codice della maestria: sangue e legname, resi con regolarita', in cambio di una maestria piu' profonda.

# --- Offerte del Negozio Gettoni spedite da questo pack (titleKey/descriptionKey espliciti -> queste chiavi) ---
shop.convert_mastery_point.title = Infusione di Maestria
shop.convert_mastery_point.desc = Converti i tuoi guadagni in una maestria piu' profonda.

# --- Valute (currency.<id>.name, risolte per convenzione; id = nome del file in minuscolo) ---
currency.mastery_point.name = Punto Maestria

