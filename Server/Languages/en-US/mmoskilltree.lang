# MMOSkillMasteryPack - quest titles + flavor, currency names, and other display text.
# Keys are bare; Hytale's I18nModule prepends the filename, so each loads as
# mmoskilltree.<key> and the mod resolves it by convention (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Add a <locale>/mmoskilltree.lang with
# the same keys to translate; missing keys fall back to English per key.

# --- Quests (quest.<id>.title / .flavor, resolved by convention; matches the bounty pattern) ---
quest.pack_first_milestone.title = First Step Toward Mastery
quest.pack_first_milestone.flavor = Prove yourself in any skill to reach your first mastery milestone. The path of mastery begins here.
quest.pack_essence_collector.title = Essence Collector
quest.pack_essence_collector.flavor = The world's essence powers mastery. Bring an offering to the altar and earn lasting power.
quest.pack_essence_devotee.title = Essence Devotee
quest.pack_essence_devotee.flavor = For those who have already proven their dedication: a greater offering for a major mastery purse.
quest.pack_path_of_mastery.title = Path of Mastery
quest.pack_path_of_mastery.flavor = True mastery is broad. Climb high in several different skills to prove your range.
quest.pack_mastery_tithe.title = Mastery Tithe
quest.pack_mastery_tithe.flavor = Pay your tithe to the mastery codex: blood and timber, rendered regularly, in exchange for a measure of mastery.

# --- Token Shop offers shipped by this pack (explicit titleKey/descriptionKey -> these keys) ---
shop.convert_mastery_point.title = Mastery Infusion
shop.convert_mastery_point.desc = Convert your earnings into deeper mastery.

# --- Currencies (currency.<id>.name, resolved by convention; id = filename lowercased) ---
