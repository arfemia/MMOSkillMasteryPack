mastery.harvesting_mastery.title = Harvesting Mastery
mastery.fireball_mastery.title = Fireball Mastery
mastery.magic_mastery.title = Magic Mastery
mastery.acrobatics_mastery.title = Acrobatics Mastery
mastery.enchanting_mastery.title = Enchanting Mastery
mastery.fishing_mastery.title = Fishing Mastery
mastery.shadowstep_mastery.title = Shadowstep Mastery
