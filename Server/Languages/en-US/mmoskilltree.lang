# MMOSkillMasteryPack - quest titles + flavor, currency names, and other display text.
# Keys are bare; Hytale's I18nModule prepends the filename, so each loads as
# mmoskilltree.<key> and the mod resolves it by convention (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Add a <locale>/mmoskilltree.lang with
# the same keys to translate; missing keys fall back to English per key.

# --- Quests (quest.<id>.title / .flavor, resolved by convention; matches the bounty pattern) ---
quest.pack_first_milestone.title = First Step Toward Mastery
quest.pack_first_milestone.flavor = Reach level 15 in any skill to earn your first Mastery Point. The path of mastery begins here.
quest.pack_essence_collector.title = Essence Collector
quest.pack_essence_collector.flavor = Life Essence powers mastery. Bring 100 to the altar and earn lasting power.
quest.pack_essence_devotee.title = Essence Devotee
quest.pack_essence_devotee.flavor = For those who have already proven their dedication: bring 500 Life Essence and earn a major mastery purse.
quest.pack_path_of_mastery.title = Path of Mastery
quest.pack_path_of_mastery.flavor = True mastery is broad. Reach level 25 in five different skills to prove your range.
quest.pack_mastery_tithe.title = Mastery Tithe
quest.pack_mastery_tithe.flavor = Pay your tithe to the mastery codex. Slay 10 mobs and chop 10 logs, then claim a Mastery Point. Requires Total Level 500 and the Mastery Hoarder achievement. Available again 6 hours after each claim.

# --- Token Shop offers shipped by this pack (explicit titleKey/descriptionKey -> these keys) ---
shop.convert_mastery_point.title = Mastery Infusion (+1 Mastery Point)
shop.convert_mastery_point.desc = Convert Bounty Tokens into a Mastery Point.

