# --- Logros (achievement.<id>.title / .desc, resueltos por convención) ---
achievement.pack_first_mastery_milestone.title = Aprendiz de la Senda
achievement.pack_first_mastery_milestone.desc = Alcanza el nivel 15 en cualquier habilidad - el primer hito de Punto de Maestría.
achievement.pack_mastery_milestone_journeyman.title = Veterano de la Senda
achievement.pack_mastery_milestone_journeyman.desc = Alcanza el nivel 60 en cualquier habilidad - cuatro hitos de Punto de Maestría conseguidos.
achievement.pack_mastery_hoarder_300.title = Acaparador de Maestría
achievement.pack_mastery_hoarder_300.desc = Gana 300 Puntos de Maestría a lo largo de tu vida.
achievement.pack_mastery_devotee.title = Devoto de la Maestría
achievement.pack_mastery_devotee.desc = El viaje completo de la maestría: un aprendiz, un veterano y un acaparador.
achievement.pack_essence_hoarder_100.title = Acaparador de Esencia I
achievement.pack_essence_hoarder_100.desc = Recoge Esencia de Vida 100 veces distintas
achievement.pack_essence_hoarder_10000.title = Acaparador de Esencia II
achievement.pack_essence_hoarder_10000.desc = Recoge Esencia de Vida 10.000 veces distintas a lo largo de tu vida - un verdadero recipiente para la energía del mundo.
