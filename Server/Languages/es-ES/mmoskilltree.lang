# MMOSkillMasteryPack - títulos de misiones + ambientación, nombres de monedas y otro texto de pantalla.
# Las claves van sin prefijo; el I18nModule de Hytale antepone el nombre del archivo, así que cada una se carga como
# mmoskilltree.<key> y el mod la resuelve por convención (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Añade un <locale>/mmoskilltree.lang con
# las mismas claves para traducir; las claves que falten recurren al inglés clave por clave.

# --- Misiones (quest.<id>.title / .flavor, resueltas por convención; sigue el patrón de los contratos) ---
quest.pack_first_milestone.title = Primer Paso Hacia la Maestría
quest.pack_first_milestone.flavor = Demuestra tu valía en cualquier habilidad para alcanzar tu primer hito de maestría. La senda de la maestría empieza aquí.
quest.pack_essence_collector.title = Coleccionista de Esencia
quest.pack_essence_collector.flavor = La esencia del mundo alimenta la maestría. Lleva una ofrenda al altar y gana un poder duradero.
quest.pack_essence_devotee.title = Devoto de la Esencia
quest.pack_essence_devotee.flavor = Para quienes ya han probado su entrega: una ofrenda mayor a cambio de una gran bolsa de maestría.
quest.pack_path_of_mastery.title = Senda de la Maestría
quest.pack_path_of_mastery.flavor = La verdadera maestría es amplia. Llega alto en varias habilidades distintas para demostrar tu versatilidad.
quest.pack_mastery_tithe.title = Diezmo de Maestría
quest.pack_mastery_tithe.flavor = Paga tu diezmo al códice de maestría: sangre y madera, rendidas con regularidad, a cambio de una maestría más profunda.

# --- Ofertas de la Tienda de Tokens incluidas en este pack (titleKey/descriptionKey explícitos -> estas claves) ---
shop.convert_mastery_point.title = Infusión de Maestría
shop.convert_mastery_point.desc = Convierte tus ganancias en una maestría más profunda.

# --- Monedas (currency.<id>.name, resuelto por convención; id = nombre de archivo en minúsculas) ---
currency.mastery_point.name = Punto de Maestría

