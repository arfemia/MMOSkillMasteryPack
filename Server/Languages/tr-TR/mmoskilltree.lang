# --- Başarımlar (achievement.<id>.title / .desc, kurala göre çözülür) ---
achievement.pack_first_mastery_milestone.title = Yolun Çırağı
achievement.pack_first_mastery_milestone.desc = Herhangi bir yetenekte 15. seviyeye ulaş - ilk Ustalık Puanı dönüm noktası.
achievement.pack_mastery_milestone_journeyman.title = Yolun Kalfası
achievement.pack_mastery_milestone_journeyman.desc = Herhangi bir yetenekte 60. seviyeye ulaş - dört Ustalık Puanı dönüm noktası kazanıldı.
achievement.pack_mastery_hoarder_300.title = Ustalık Biriktiricisi
achievement.pack_mastery_hoarder_300.desc = Yaşamın boyunca 300 Ustalık Puanı kazan.
achievement.pack_mastery_devotee.title = Ustalık Müridi
achievement.pack_mastery_devotee.desc = Tam ustalık yolculuğu: bir çırak, bir kalfa ve bir biriktirici.
achievement.pack_essence_hoarder_100.title = Öz Biriktiricisi I
achievement.pack_essence_hoarder_100.desc = Yaşam Özünü 100 farklı kez topla
achievement.pack_essence_hoarder_10000.title = Öz Biriktiricisi II
achievement.pack_essence_hoarder_10000.desc = Yaşamın boyunca Yaşam Özünü 10.000 farklı kez topla - dünyanın enerjisi için gerçek bir kap.
