# MMOSkillMasteryPack - titres + ambiance des quêtes, noms des monnaies et autres textes affichés.
# Les clés sont nues ; l'I18nModule de Hytale ajoute le nom de fichier en préfixe, donc chaque clé
# se charge comme mmoskilltree.<key> et le mod la résout par convention (quest.<id>.title / .flavor,
# currency.<id>.name, shop.<id>.title / .desc, ...). Ajoutez un fichier <locale>/mmoskilltree.lang
# avec les mêmes clés pour traduire ; les clés manquantes retombent sur l'anglais clé par clé.

# --- Quêtes (quest.<id>.title / .flavor, résolues par convention ; même schéma que les primes) ---
quest.pack_first_milestone.title = Premier pas vers la maîtrise
quest.pack_first_milestone.flavor = Atteignez le niveau 15 dans n'importe quelle compétence pour gagner votre premier Point de maîtrise. La voie de la maîtrise commence ici.
quest.pack_essence_collector.title = Collecteur d'essence
quest.pack_essence_collector.flavor = L'essence de vie alimente la maîtrise. Apportez-en 100 à l'autel et gagnez un pouvoir durable.
quest.pack_essence_devotee.title = Dévot de l'essence
quest.pack_essence_devotee.flavor = Pour ceux qui ont déjà prouvé leur dévouement : apportez 500 essences de vie et gagnez une grosse bourse de maîtrise.
quest.pack_path_of_mastery.title = Voie de la maîtrise
quest.pack_path_of_mastery.flavor = La vraie maîtrise est vaste. Atteignez le niveau 25 dans cinq compétences différentes pour prouver votre polyvalence.
quest.pack_mastery_tithe.title = Dîme de la maîtrise
quest.pack_mastery_tithe.flavor = Payez votre dîme au codex de la maîtrise. Tuez 10 mobs et coupez 10 bûches, puis réclamez un Point de maîtrise. Nécessite le Niveau total 500 et le succès Amasseur de maîtrise. De nouveau disponible 6 heures après chaque réclamation.

# --- Offres de la Boutique de tokens livrées par ce pack (titleKey/descriptionKey explicites -> ces clés) ---
shop.convert_mastery_point.title = Infusion de maîtrise (+1 Point de maîtrise)
shop.convert_mastery_point.desc = Convertissez des tokens de prime en Point de maîtrise.

# --- Monnaies (currency.<id>.name, résolu par convention ; id = nom de fichier en minuscules) ---
currency.life_essence.name = Essence de vie
currency.mastery_point.name = Point de maîtrise

