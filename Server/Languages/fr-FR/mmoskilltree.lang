# --- Succès (achievement.<id>.title / .desc, résolus par convention) ---
achievement.pack_first_mastery_milestone.title = Apprenti de la voie
achievement.pack_first_mastery_milestone.desc = Atteignez le niveau 15 dans n'importe quelle compétence, le premier palier de Point de maîtrise.
achievement.pack_mastery_milestone_journeyman.title = Compagnon de la voie
achievement.pack_mastery_milestone_journeyman.desc = Atteignez le niveau 60 dans n'importe quelle compétence, quatre paliers de Point de maîtrise gagnés.
achievement.pack_mastery_hoarder_300.title = Amasseur de maîtrise
achievement.pack_mastery_hoarder_300.desc = Gagnez 300 Points de maîtrise au cours de votre vie.
achievement.pack_mastery_devotee.title = Dévot de la maîtrise
achievement.pack_mastery_devotee.desc = Le parcours complet de la maîtrise : un apprenti, un compagnon et un amasseur.
achievement.pack_essence_hoarder_100.title = Amasseur d'essence I
achievement.pack_essence_hoarder_100.desc = Ramassez de l'essence de vie 100 fois différentes
achievement.pack_essence_hoarder_10000.title = Amasseur d'essence II
achievement.pack_essence_hoarder_10000.desc = Ramassez de l'essence de vie 10 000 fois différentes au cours de votre vie, un véritable réceptacle de l'énergie du monde.

